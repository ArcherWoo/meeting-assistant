# ── 构建产物 ──────────────────────────────────────────────────
dist/
dist-electron/
build/
release/
out/

# ── Node.js 依赖 ───────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Python 缓存 ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/
pip-wheel-metadata/

# ── 环境变量 / API Key（绝不提交！） ──────────────────────────
.env
.env.local
.env.*.local
backend/.env
*.secret

# ── 用户本地数据（数据库 & 向量库） ──────────────────────────
# 注意：~/ 路径不需要在这里列出，git 只追踪项目内的文件
# 如果你在项目目录内存有数据文件，请加在下面：
*.db
*.sqlite
*.sqlite3
vectors/
lancedb_data/

# ── macOS ──────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# ── IDE / 编辑器 ───────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo

# ── Electron Builder 临时文件 ──────────────────────────────────
*.spec
.cache/

# ── 日志 ──────────────────────────────────────────────────────
logs/
*.log

