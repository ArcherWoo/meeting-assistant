# 统一换行符：所有文本文件在仓库中存储为 LF，签出时根据平台自动转换
* text=auto eol=lf

# 确保脚本文件始终使用 LF
*.sh text eol=lf
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Windows 批处理文件使用 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# 二进制文件不做换行符转换
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.pptx binary
*.docx binary
*.xlsx binary

