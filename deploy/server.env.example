# Meeting Assistant server deployment example
# Copy this file to deploy/server.env and adjust values for your server.

# Network
MEETING_ASSISTANT_HOST=0.0.0.0
MEETING_ASSISTANT_PORT=5173

# Frontend hosting
# The backend can directly serve the built frontend from dist/.
MEETING_ASSISTANT_SERVE_FRONTEND=1
MEETING_ASSISTANT_FRONTEND_DIST=./dist

# Runtime data
MEETING_ASSISTANT_HOME=./.server-data
MEETING_ASSISTANT_LOG_DIR=./.server-data/logs
MEETING_ASSISTANT_NGINX_HOME=

# Runner behavior
MEETING_ASSISTANT_RESTART_DELAY=5
MEETING_ASSISTANT_LOG_LEVEL=info
MEETING_ASSISTANT_LOG_FORMAT=json
MEETING_ASSISTANT_RUNTIME_COORDINATION=sqlite

# Python runtime
# Optional: point to a specific Python executable if you do not want to use .server-venv/.
MEETING_ASSISTANT_PYTHON_EXECUTABLE=
# By default, .server-venv reuses packages already available in the current Python environment.
# Keep this enabled on corporate networks so production deploy can align with python start.py.
MEETING_ASSISTANT_VENV_SYSTEM_SITE_PACKAGES=1

# Corporate pip mirror settings
# Fill these values when your server can only access an internal package source.
MEETING_ASSISTANT_PIP_INDEX_URL=
MEETING_ASSISTANT_PIP_EXTRA_INDEX_URL=
MEETING_ASSISTANT_PIP_TRUSTED_HOST=
MEETING_ASSISTANT_PIP_FIND_LINKS=
MEETING_ASSISTANT_PIP_NO_INDEX=
MEETING_ASSISTANT_PIP_ARGS=

# Process settings
# Linux: workers means uvicorn workers on one port.
# Windows: when runtime coordination=sqlite and workers>1, service_runner will
# automatically run multiple single-worker backend instances on sequential ports
# starting from MEETING_ASSISTANT_PORT, then let Nginx aggregate them.
MEETING_ASSISTANT_WORKERS=1
MEETING_ASSISTANT_TIMEOUT_KEEP_ALIVE=30
MEETING_ASSISTANT_BACKLOG=2048
MEETING_ASSISTANT_LIMIT_CONCURRENCY=0
MEETING_ASSISTANT_LIMIT_MAX_REQUESTS=0
MEETING_ASSISTANT_ENABLE_ACCESS_LOG=0

# Reverse proxy settings
# Recommended when using Nginx in front of the app.
MEETING_ASSISTANT_PROXY_HEADERS=1
MEETING_ASSISTANT_FORWARDED_ALLOW_IPS=127.0.0.1

# LLM / embedding configuration is not stored here.
# Admins configure those inside the app settings UI.
