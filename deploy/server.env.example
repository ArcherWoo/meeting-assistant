# Server deployment config for Meeting Assistant
# Copy to deploy/server.env and adjust when needed.

# ── 服务监听 ──────────────────────────────────────────────────────────────────
MEETING_ASSISTANT_HOST=0.0.0.0
MEETING_ASSISTANT_PORT=5173

# ── 前端静态文件 ──────────────────────────────────────────────────────────────
# 生产部署由 FastAPI 直接托管编译后的前端，无需单独的前端服务器
MEETING_ASSISTANT_SERVE_FRONTEND=1
MEETING_ASSISTANT_FRONTEND_DIST=./dist

# ── 数据目录 ──────────────────────────────────────────────────────────────────
# 所有持久化数据（SQLite 数据库、向量索引、用户 Skill）存放于此目录
MEETING_ASSISTANT_HOME=./.server-data
MEETING_ASSISTANT_LOG_DIR=./.server-data/logs

# ── 守护进程 ──────────────────────────────────────────────────────────────────
MEETING_ASSISTANT_RESTART_DELAY=5
MEETING_ASSISTANT_LOG_LEVEL=info

# ── LLM / Agent 配置说明 ──────────────────────────────────────────────────────
# LLM 的 API Key、Base URL 和模型名称【不在此处配置】。
# 这些信息由用户在"设置 → LLM 配置"面板中填写，安全存储于 SQLite 数据库内。
# Agent 执行时前端将当前激活的 LLM 配置随请求一并发送，无需服务器端环境变量。
